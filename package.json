{
  "name": "claude-canvas",
  "version": "1.0.0",
  "description": "A shared visual canvas for Claude Code",
  "license": "MIT",
  "author": "Udi Talias",
  "repository": {
    "type": "git",
    "url": "https://github.com/uditalias/claude-canvas.git"
  },
  "homepage": "https://github.com/uditalias/claude-canvas#readme",
  "bugs": {
    "url": "https://github.com/uditalias/claude-canvas/issues"
  },
  "keywords": [
    "claude",
    "canvas",
    "claude-code",
    "visual",
    "drawing",
    "whiteboard",
    "ai"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "claude-canvas": "./dist/bin/claude-canvas.js"
  },
  "files": [
    "dist/",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build --config vite.config.ts",
    "build:server": "node scripts/build-server.js",
    "dev": "tsx src/bin/claude-canvas.ts",
    "dev:client": "vite --config vite.config.ts",
    "prepublishOnly": "npm test && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "node scripts/release.js",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^12.0.0",
    "express": "^4.18.0",
    "fabric": "^7.2.0",
    "lucide-react": "^1.7.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "roughjs": "^4.6.6",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.27.4",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
