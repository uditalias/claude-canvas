{
  "name": "claude-canvas",
  "version": "1.0.0",
  "description": "A shared visual canvas for Claude Code",
  "bin": {
    "claude-canvas": "./dist/bin/claude-canvas.js"
  },
  "scripts": {
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build --config vite.config.ts",
    "build:server": "esbuild src/bin/claude-canvas.ts src/server/index.ts --bundle --platform=node --outdir=dist --format=cjs --external:esbuild",
    "dev": "tsx src/bin/claude-canvas.ts",
    "dev:client": "vite --config vite.config.ts"
  },
  "dependencies": {
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^12.0.0",
    "express": "^4.18.0",
    "fabric": "^7.2.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "roughjs": "^4.6.6",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.27.4",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
